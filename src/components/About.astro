<section id="about" class="section-y border-y border-white/[0.06] bg-white/[0.02]">
  <div class="container-zen">
    <div class="grid items-center gap-14 lg:grid-cols-2">
      <div>
        <h2 class="font-display text-3xl font-bold tracking-tight text-white sm:text-4xl">About ZenKube</h2>
        <p class="mt-4 text-lg leading-relaxed text-zinc-400">
          We are consultants and engineers who care about outcomes: stable releases, understandable systems, and teams that
          are not afraid to change software because the path to production is clear.
        </p>
        <h3 class="mt-10 font-display text-lg font-semibold text-white">Our mission</h3>
        <p class="mt-3 text-sm leading-relaxed text-zinc-400">
          Empower organizations with practical architecture, secure delivery, and human-centered communication—so digital
          transformation becomes momentum, not slogans.
        </p>
        <ul class="mt-8 space-y-4 text-sm text-zinc-300">
          <li class="flex gap-3">
            <span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-emerald-400 shadow-[0_0_10px_#34d399]"></span>
            <span><strong class="text-white">Senior practitioners</strong> — hands-on work, not endless slide decks.</span>
          </li>
          <li class="flex gap-3">
            <span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-violet-400 shadow-[0_0_10px_#a78bfa]"></span>
            <span><strong class="text-white">Vendor-neutral guidance</strong> — recommendations grounded in your constraints.</span>
          </li>
          <li class="flex gap-3">
            <span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-sky-400 shadow-[0_0_10px_#38bdf8]"></span>
            <span><strong class="text-white">Customer success focus</strong> — documentation and enablement built into delivery.</span>
          </li>
        </ul>
      </div>
      <div class="surface relative overflow-hidden p-10">
        <div
          class="pointer-events-none absolute -right-16 top-0 h-64 w-64 rounded-full bg-gradient-to-bl from-emerald-500/25 via-transparent to-transparent blur-3xl"
          aria-hidden="true"
        ></div>
        <p class="text-xs font-bold uppercase tracking-[0.25em] text-zinc-500">How we work</p>
        <div class="mt-8 grid grid-cols-2 gap-4 sm:gap-6">
          <div class="rounded-xl border border-white/10 bg-white/[0.04] p-5">
            <p class="text-3xl font-display font-bold text-white">Global</p>
            <p class="mt-1 text-xs text-zinc-500">Remote-first delivery across time zones</p>
          </div>
          <div class="rounded-xl border border-white/10 bg-white/[0.04] p-5">
            <p class="text-3xl font-display font-bold gradient-text">24/7</p>
            <p class="mt-1 text-xs text-zinc-500">On-call patterns tailored to your SLA</p>
          </div>
          <div class="col-span-2 rounded-xl border border-dashed border-emerald-400/25 bg-emerald-500/[0.06] p-5">
            <p class="text-sm font-medium text-emerald-100/90">Engagement snapshot</p>
            <p class="mt-2 text-sm text-zinc-400">
              Typical projects span discovery workshops, reference architectures, implementation sprints, and knowledge
              transfer—so your internal team owns the runway.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
