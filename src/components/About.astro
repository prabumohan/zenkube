---
const steps = [
  {
    title: 'Principles',
    body: 'We bias to small batches, reversible changes, and documentation that survives employee turnover.',
  },
  {
    title: 'Who we are',
    body: 'Senior engineers and architects who still write code and still carry pagers when the engagement requires it.',
  },
  {
    title: 'How we price',
    body: 'Time-and-materials or fixed phases with explicit exit criteria—no open-ended “transformation” retainers without milestones.',
  },
];
---

<section id="about" class="section-y border-y border-white/[0.06] bg-white/[0.015]">
  <div class="container-zen max-w-3xl">
    <p class="eyebrow text-zinc-500">Studio</p>
    <h2 class="mt-3 font-display text-3xl font-bold tracking-tight text-white sm:text-4xl">About ZenKube</h2>
    <p class="mt-5 text-lg leading-relaxed text-zinc-400">
      ZenKube is a boutique practice—not a volume agency. We take a handful of concurrent engagements so response times
      stay honest and context does not evaporate between meetings.
    </p>

    <ul class="mt-12 space-y-10 border-l border-emerald-500/20 pl-8">
      {
        steps.map((step, i) => (
          <li class="relative">
            <span
              class="absolute -left-8 top-1.5 flex h-3 w-3 translate-x-[calc(-50%-0.5px)] rounded-full border-2 border-emerald-400/70 bg-zen-950 shadow-[0_0_12px_rgba(52,211,153,0.35)]"
              aria-hidden="true"
            />
            <p class="eyebrow text-emerald-200/50">0{i + 1}</p>
            <h3 class="mt-2 font-display text-lg font-semibold text-white">{step.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-zinc-500">{step.body}</p>
          </li>
        ))
      }
    </ul>

    <div class="mt-12 grid gap-4 sm:grid-cols-2">
      <div class="surface-muted p-6">
        <p class="font-display text-2xl font-bold text-white">Remote-first</p>
        <p class="mt-2 text-sm text-zinc-500">Workshops and reviews over secure video; on-site when it genuinely helps.</p>
      </div>
      <div class="surface-muted p-6">
        <p class="font-display text-2xl font-bold gradient-text">UTC± friendly</p>
        <p class="mt-2 text-sm text-zinc-500">Overlap windows agreed up front—no surprise midnight calls.</p>
      </div>
    </div>
  </div>
</section>
