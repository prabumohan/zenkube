---
const mail = 'contact@zenkube.dev';
---

<section id="contact" class="section-y">
  <div class="container-zen">
    <div class="grid gap-12 lg:grid-cols-12 lg:gap-10">
      <div class="lg:col-span-5">
        <p class="eyebrow text-zinc-500">Contact</p>
        <h2 class="mt-3 font-display text-3xl font-bold tracking-tight text-white sm:text-4xl">Tell us what you are building</h2>
        <p class="mt-4 text-base leading-relaxed text-zinc-400">
          Share enough context that we can reply with substance—stack, constraints, and what “done” looks like on your side.
        </p>
        <a
          href={`mailto:${mail}?subject=${encodeURIComponent('ZenKube — project inquiry')}`}
          class="btn-primary mt-8 inline-flex w-full justify-center sm:w-auto"
        >
          Email {mail}
        </a>
        <p class="mt-4 text-xs text-zinc-600">We aim to respond within two business days.</p>
      </div>

      <div class="lg:col-span-7">
        <form id="zk-contact-form" class="surface space-y-5 p-8">
          <div>
            <label for="name" class="mb-2 block text-xs font-semibold uppercase tracking-wider text-zinc-500">Name</label>
            <input
              type="text"
              id="name"
              name="name"
              autocomplete="name"
              required
              class="w-full rounded-xl border border-white/10 bg-zen-900/80 px-4 py-3 text-sm text-white outline-none transition focus:border-emerald-400/40 focus:ring-4 focus:ring-emerald-400/15"
            />
          </div>
          <div>
            <label for="email" class="mb-2 block text-xs font-semibold uppercase tracking-wider text-zinc-500">Work email</label>
            <input
              type="email"
              id="email"
              name="email"
              autocomplete="email"
              required
              class="w-full rounded-xl border border-white/10 bg-zen-900/80 px-4 py-3 text-sm text-white outline-none transition focus:border-emerald-400/40 focus:ring-4 focus:ring-emerald-400/15"
            />
          </div>
          <div>
            <label for="company" class="mb-2 block text-xs font-semibold uppercase tracking-wider text-zinc-500">Company (optional)</label>
            <input
              type="text"
              id="company"
              name="company"
              autocomplete="organization"
              class="w-full rounded-xl border border-white/10 bg-zen-900/80 px-4 py-3 text-sm text-white outline-none transition focus:border-emerald-400/40 focus:ring-4 focus:ring-emerald-400/15"
            />
          </div>
          <div>
            <label for="message" class="mb-2 block text-xs font-semibold uppercase tracking-wider text-zinc-500">Message</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              class="w-full resize-y rounded-xl border border-white/10 bg-zen-900/80 px-4 py-3 text-sm text-white outline-none transition focus:border-emerald-400/40 focus:ring-4 focus:ring-emerald-400/15"
            ></textarea>
          </div>
          <button type="submit" class="btn-primary w-full">Compose in email</button>
          <p class="text-center text-xs text-zinc-500">
            Opens your mail client with this message prefilled—no data is stored on our servers.
          </p>
        </form>
      </div>
    </div>
  </div>
</section>

<script is:inline define:vars={{ mail }}>
  (function () {
    var form = document.getElementById('zk-contact-form');
    if (!form) return;
    form.addEventListener('submit', function (e) {
      e.preventDefault();
      var nameEl = document.getElementById('name');
      var emailEl = document.getElementById('email');
      var companyEl = document.getElementById('company');
      var messageEl = document.getElementById('message');
      var name = nameEl && nameEl.value ? nameEl.value.trim() : '';
      var email = emailEl && emailEl.value ? emailEl.value.trim() : '';
      var company = companyEl && companyEl.value ? companyEl.value.trim() : '';
      var message = messageEl && messageEl.value ? messageEl.value.trim() : '';
      if (!name || !email || !message) return;
      var body =
        'Name: ' +
        name +
        '\n' +
        'Email: ' +
        email +
        (company ? '\nCompany: ' + company : '') +
        '\n\n' +
        message;
      var subject = 'ZenKube — project inquiry' + (company ? ' — ' + company : '');
      window.location.href =
        'mailto:' + mail + '?subject=' + encodeURIComponent(subject) + '&body=' + encodeURIComponent(body);
    });
  })();
</script>
