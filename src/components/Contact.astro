---
---

<section id="contact" class="section-y">
  <div class="container-zen">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="font-display text-3xl font-bold tracking-tight text-white sm:text-4xl">Get in touch</h2>
      <p class="mt-4 text-lg text-zinc-400">
        Ready to modernize infrastructure or ship a new product surface? Tell us what you are aiming for—we will respond
        with clear next steps.
      </p>
    </div>

    <div class="mx-auto mt-14 grid max-w-5xl gap-10 lg:grid-cols-5">
      <form class="surface space-y-5 p-8 lg:col-span-3" onsubmit="event.preventDefault();">
        <div>
          <label for="name" class="mb-2 block text-xs font-semibold uppercase tracking-wider text-zinc-500">Name</label>
          <input
            type="text"
            id="name"
            name="name"
            autocomplete="name"
            class="w-full rounded-xl border border-white/10 bg-zen-900/80 px-4 py-3 text-sm text-white placeholder-zinc-600 outline-none ring-emerald-400/0 transition focus:border-emerald-400/40 focus:ring-4 focus:ring-emerald-400/15"
            placeholder="Your name"
          />
        </div>
        <div>
          <label for="email" class="mb-2 block text-xs font-semibold uppercase tracking-wider text-zinc-500">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            autocomplete="email"
            class="w-full rounded-xl border border-white/10 bg-zen-900/80 px-4 py-3 text-sm text-white placeholder-zinc-600 outline-none transition focus:border-emerald-400/40 focus:ring-4 focus:ring-emerald-400/15"
            placeholder="you@company.com"
          />
        </div>
        <div>
          <label for="company" class="mb-2 block text-xs font-semibold uppercase tracking-wider text-zinc-500">Company</label>
          <input
            type="text"
            id="company"
            name="company"
            autocomplete="organization"
            class="w-full rounded-xl border border-white/10 bg-zen-900/80 px-4 py-3 text-sm text-white placeholder-zinc-600 outline-none transition focus:border-emerald-400/40 focus:ring-4 focus:ring-emerald-400/15"
            placeholder="Organization"
          />
        </div>
        <div>
          <label for="message" class="mb-2 block text-xs font-semibold uppercase tracking-wider text-zinc-500">Message</label>
          <textarea
            id="message"
            name="message"
            rows="4"
            class="w-full resize-y rounded-xl border border-white/10 bg-zen-900/80 px-4 py-3 text-sm text-white placeholder-zinc-600 outline-none transition focus:border-emerald-400/40 focus:ring-4 focus:ring-emerald-400/15"
            placeholder="Goals, timelines, current stack, and any compliance requirements…"
          ></textarea>
        </div>
        <button type="submit" class="btn-primary w-full">Send message</button>
        <p class="text-center text-xs text-zinc-500">
          Static demo form—connect to Forms, Workers, or your CRM when you are ready to capture leads.
        </p>
      </form>

      <div class="flex flex-col justify-center space-y-8 lg:col-span-2">
        <div class="surface p-8">
          <h3 class="text-xs font-bold uppercase tracking-[0.2em] text-zinc-500">Email</h3>
          <a href="mailto:hello@zenkube.dev" class="mt-3 block font-display text-lg font-semibold text-emerald-300 hover:text-emerald-200">
            hello@zenkube.dev
          </a>
          <p class="mt-2 text-sm text-zinc-500">Replace with your production address before launch.</p>
        </div>
        <div class="surface p-8">
          <h3 class="text-xs font-bold uppercase tracking-[0.2em] text-zinc-500">Location</h3>
          <p class="mt-3 text-sm leading-relaxed text-zinc-400">
            Remote IT consulting with global client support—workshops and reviews run over secure video, with optional
            on-site milestones when it helps.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
