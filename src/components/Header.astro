---
import LogoDrawZK from './logos/LogoDrawZK.astro';
---

<header class="surface sticky top-4 z-50 mx-4 mt-4 sm:mx-6">
  <div class="container-zen">
    <div class="flex items-center justify-between py-4">
      <a href="#home" class="group flex items-center gap-3" aria-label="ZenKube home">
        <div
          class="flex h-10 w-10 shrink-0 items-center justify-center overflow-hidden rounded-xl shadow-glow-sm ring-1 ring-white/10 transition group-hover:scale-[1.02] group-hover:ring-emerald-400/30"
          aria-hidden="true"
        >
          <LogoDrawZK size={40} />
        </div>
        <span class="font-display text-lg font-semibold tracking-tight text-white">ZenKube</span>
      </a>

      <nav class="desktop-nav hidden items-center gap-8 md:flex">
        <a href="#home" class="nav-link">Home</a>
        <a href="#services" class="nav-link">Services</a>
        <a href="#technologies" class="nav-link">Stack</a>
        <a href="#about" class="nav-link">About</a>
        <a href="#contact" class="nav-link">Contact</a>
      </nav>

      <div class="hidden items-center gap-3 md:flex">
        <a href="#contact" class="btn-primary">Get started</a>
      </div>

      <div class="md:hidden">
        <button
          type="button"
          onclick="toggleMobileMenu()"
          class="rounded-lg p-2 text-zinc-300 hover:bg-white/5 hover:text-emerald-300 focus:outline-none focus:ring-2 focus:ring-emerald-400/40"
          aria-label="Open menu"
        >
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" id="menu-icon">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>

    <div id="mobile-menu" class="hidden md:hidden">
      <div class="space-y-1 border-t border-white/10 px-2 py-4">
        <a href="#home" class="block rounded-lg px-3 py-2.5 nav-link">Home</a>
        <a href="#services" class="block rounded-lg px-3 py-2.5 nav-link">Services</a>
        <a href="#technologies" class="block rounded-lg px-3 py-2.5 nav-link">Stack</a>
        <a href="#about" class="block rounded-lg px-3 py-2.5 nav-link">About</a>
        <a href="#contact" class="block rounded-lg px-3 py-2.5 nav-link">Contact</a>
        <div class="pt-3">
          <a href="#contact" class="btn-primary w-full text-center">Get started</a>
        </div>
      </div>
    </div>
  </div>
</header>
