---
---

<header class="surface sticky top-4 z-50 mx-4 mt-4 sm:mx-6">
  <div class="container-zen">
    <div class="flex items-center justify-between py-4">
      <a href="#home" class="group flex items-center gap-3">
        <div
          class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-emerald-400 to-teal-600 text-sm font-bold text-zen-950 shadow-glow-sm transition group-hover:scale-[1.02]"
        >
          ZK
        </div>
        <div class="flex flex-col leading-none">
          <span class="font-display text-lg font-semibold tracking-tight text-white">ZenKube</span>
          <span class="text-[11px] font-medium uppercase tracking-[0.2em] text-zinc-500">Ops hub</span>
        </div>
      </a>

      <nav class="desktop-nav hidden items-center gap-8 md:flex">
        <a href="#home" class="nav-link">Home</a>
        <a href="#services" class="nav-link">Capabilities</a>
        <a href="#technologies" class="nav-link">Platform</a>
        <a href="#about" class="nav-link">About</a>
        <a href="#contact" class="nav-link">Contact</a>
      </nav>

      <div class="hidden items-center gap-3 md:flex">
        <a href="#contact" class="btn-primary">Get early access</a>
      </div>

      <div class="md:hidden">
        <button
          type="button"
          onclick="toggleMobileMenu()"
          class="rounded-lg p-2 text-zinc-300 hover:bg-white/5 hover:text-emerald-300 focus:outline-none focus:ring-2 focus:ring-emerald-400/40"
          aria-label="Open menu"
        >
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" id="menu-icon">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>

    <div id="mobile-menu" class="hidden md:hidden">
      <div class="space-y-1 border-t border-white/10 px-2 py-4">
        <a href="#home" class="block rounded-lg px-3 py-2.5 nav-link">Home</a>
        <a href="#services" class="block rounded-lg px-3 py-2.5 nav-link">Capabilities</a>
        <a href="#technologies" class="block rounded-lg px-3 py-2.5 nav-link">Platform</a>
        <a href="#about" class="block rounded-lg px-3 py-2.5 nav-link">About</a>
        <a href="#contact" class="block rounded-lg px-3 py-2.5 nav-link">Contact</a>
        <div class="pt-3">
          <a href="#contact" class="btn-primary w-full text-center">Get early access</a>
        </div>
      </div>
    </div>
  </div>
</header>
