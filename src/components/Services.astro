<section id="services" class="section-y border-y border-white/[0.06] bg-gradient-to-b from-white/[0.02] to-transparent">
  <div class="container-zen">
    <div class="max-w-2xl">
      <p class="eyebrow text-emerald-200/60">Capability</p>
      <h2 class="mt-3 font-display text-3xl font-bold tracking-tight text-white sm:text-4xl">Where we plug in</h2>
      <p class="mt-4 text-lg leading-relaxed text-zinc-400">
        Pick one lane to start or combine a few—each block below is a slice of work we have led end-to-end for product and
        platform teams.
      </p>
    </div>

    <div class="mt-14 grid gap-4 lg:grid-cols-12">
      {
        items.map((item) => (
          <article class:list={['surface group relative overflow-hidden p-7 lg:p-8', item.span]}>
            <div
              class="pointer-events-none absolute -right-8 -top-8 h-32 w-32 rounded-full bg-gradient-to-br from-violet-500/15 to-transparent opacity-0 blur-2xl transition group-hover:opacity-100"
              aria-hidden="true"
            />
            <div class="mb-5 inline-flex rounded-xl bg-white/[0.06] p-3 ring-1 ring-white/10">
              <svg class="h-7 w-7 text-emerald-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d={item.icon} />
              </svg>
            </div>
            <h3 class="font-display text-lg font-semibold text-white">{item.title}</h3>
            <p class="mt-2 max-w-prose text-sm leading-relaxed text-zinc-400">{item.body}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
