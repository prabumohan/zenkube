---
const items = [
  {
    title: 'Unified stock view',
    body: 'One ledger-style view for SKUs, locations, and quantities—tuned for teams who outgrew spreadsheets.',
    icon: 'M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4',
  },
  {
    title: 'Low-friction updates',
    body: 'Fast edits from the warehouse or desk with layouts that stay thumb-friendly on smaller screens.',
    icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z',
  },
  {
    title: 'Shared workspaces',
    body: 'Spaces per partner or site so everyone sees the right scope—without duplicating the whole catalog.',
    icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4',
  },
  {
    title: 'Exports & handoff',
    body: 'CSV-friendly structures when you need to reconcile with accounting or upstream suppliers.',
    icon: 'M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
  },
  {
    title: 'Ops notifications',
    body: 'Surface thresholds and handoffs so the next person in line knows what changed since they last looked.',
    icon: 'M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9',
  },
  {
    title: 'Composable backend',
    body: 'Start static; add Cloudflare D1, Workers, or your API when you need multi-device truth.',
    icon: 'M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01',
  },
];
---

<section id="services" class="section-y border-y border-white/[0.06] bg-white/[0.02]">
  <div class="container-zen">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="font-display text-3xl font-bold tracking-tight text-white sm:text-4xl">Capabilities</h2>
      <p class="mt-4 text-lg text-zinc-400">
        Opinionated defaults for inventory-heavy teams—without the bloat of legacy ERP portals.
      </p>
    </div>

    <div class="mt-16 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        items.map((item) => (
          <article class="surface group relative overflow-hidden p-7">
            <div
              class="pointer-events-none absolute -right-8 -top-8 h-32 w-32 rounded-full bg-gradient-to-br from-emerald-500/20 to-transparent opacity-0 blur-2xl transition group-hover:opacity-100"
              aria-hidden="true"
            />
            <div class="mb-5 inline-flex rounded-xl bg-white/[0.06] p-3 ring-1 ring-white/10">
              <svg class="h-7 w-7 text-emerald-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d={item.icon} />
              </svg>
            </div>
            <h3 class="font-display text-lg font-semibold text-white">{item.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-zinc-400">{item.body}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
